<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Launcher Orbital Arc Sweep (representing launching, flow, and direct access) -->
    <path
        android:pathData="M 28,68 A 28,28 0 0,1 68,28"
        android:strokeWidth="3.5"
        android:strokeLineCap="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="28"
                android:startY="68"
                android:endX="68"
                android:endY="28"
                android:type="linear">
                <item android:offset="0.0" android:color="#3300E5FF" />
                <item android:offset="0.5" android:color="#8042A5F5" />
                <item android:offset="1.0" android:color="#FF42A5F5" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Launcher Arrowhead / Rocket Tip (representing the quick start / launcher) -->
    <path
        android:pathData="M 74,22 L 60,25 L 67,32 Z"
        android:fillColor="#FF00E5FF" />

    <!-- Magnifying Glass Ring (representing search) -->
    <path
        android:pathData="M 50,33 A 15,15 0 1,1 49.9,33 Z"
        android:strokeWidth="5"
        android:strokeLineCap="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="35"
                android:startY="33"
                android:endX="65"
                android:endY="63"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF90CAF9" />
                <item android:offset="1.0" android:color="#FF2196F3" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Magnifying Glass Handle -->
    <path
        android:pathData="M 60.6,58.6 L 75,73"
        android:strokeWidth="5.5"
        android:strokeLineCap="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="60.6"
                android:startY="58.6"
                android:endX="75"
                android:endY="73"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF2196F3" />
                <item android:offset="1.0" android:color="#FFAB47BC" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Central Glowing Sparkle Star (representing AI Smart Analysis & Insight) -->
    <path
        android:pathData="M 50,38 Q 50,48 40,48 Q 50,48 50,58 Q 50,48 60,48 Q 50,48 50,38 Z"
        android:fillColor="#FFFFFF" />

</vector>
